{
  "name": "afribok-mobile",
  "version": "2026.1.0",
  "description": "Afribok Healthcare System - Mobile App",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:android": "expo start --android",
    "start:ios": "expo start --ios",
    "eject": "expo eject",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:all": "eas build --platform all",
    "test": "jest"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.0",
    "expo": "^49.0.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native-stack": "^6.9.0",
    "react-native-screens": "~3.22.0",
    "react-native-safe-area-context": "4.6.0",
    "react-native-gesture-handler": "~2.12.0",
    "axios": "^1.6.0",
    "zustand": "^4.4.0",
    "@react-native-async-storage/async-storage": "~1.18.0",
    "react-native-sqlite-storage": "^6.0.0",
    "react-native-netinfo": "^9.3.0",
    "@react-native-camera-roll/camera-roll": "^5.7.0",
    "react-native-webrtc": "^106.0.0",
    "react-native-background-timer": "^2.4.1",
    "expo-font": "~11.4.0",
    "expo-splash-screen": "~0.20.0",
    "expo-status-bar": "~1.6.0",
    "@expo/vector-icons": "^13.0.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.0.0",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "jest-expo": "^49.0.0"
  },
  "expo": {
    "name": "Afribok",
    "slug": "afribok",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.afribok.healthcare"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.afribok.healthcare"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-file-system"
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Afribok to access your camera for telemedicine consultations"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Afribok to access emergency contacts"
        }
      ]
    ]
  }
}
