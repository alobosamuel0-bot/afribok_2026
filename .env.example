# Afribok Environment Configuration
# Copy to .env and fill with actual values

# ============= APP CONFIG =============
APP_NAME=Afribok
APP_VERSION=2026.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ============= DATABASE =============
# Local SQLite for offline mode
LOCAL_DB_URL=sqlite+aiosqlite:///./data/afribok_local.db

# Central PostgreSQL
CENTRAL_DB_URL=postgresql+asyncpg://afribok:securepassword@localhost:5432/afribok_central
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ============= REDIS/CACHE =============
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=600

# ============= JWT/SECURITY =============
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============= CORS =============
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8100
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH
ALLOWED_HEADERS=*

# ============= FILE STORAGE =============
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# ============= SYNC ENGINE =============
SYNC_ENABLED=true
SYNC_INTERVAL_SECONDS=300
SYNC_BATCH_SIZE=1000
OFFLINE_MODE=false

# ============= ML/AI =============
ML_MODEL_PATH=./models
PREDICTION_CACHE_TTL=3600
ENABLE_PREDICTIONS=true

# ============= ALERTS =============
ALERT_ENABLED=true
ALERT_CAPACITY_THRESHOLD=0.85
ALERT_EMAIL_ENABLED=false
ALERT_SMS_ENABLED=false

# ============= EXTERNAL SERVICES =============
# Twilio (for SMS/WhatsApp)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SMTP (for Email)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ============= MONITORING =============
SENTRY_DSN=https://key@sentry.io/123456
SENTRY_ENVIRONMENT=development

# ============= AUDIT & LOGGING =============
AUDIT_LOG_DIR=./logs
STORE_AUDIT_LOGS=true

# ============= PERFORMANCE =============
ENABLE_RESPONSE_CACHING=true
ENABLE_QUERY_OPTIMIZATION=true
DATABASE_SLOW_QUERY_THRESHOLD_MS=1000
